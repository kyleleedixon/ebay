# eBay API — fill these in from developer.ebay.com → Application Keysets (Production)
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
# Either "PRODUCTION" or "SANDBOX". Use SANDBOX while testing without burning rate limits.
EBAY_ENV=PRODUCTION

# Marketplace Insights API (sold-comp data). Requires separate approval from eBay.
# Set to "true" once approved; otherwise the scanner falls back to active-listing comps.
EBAY_INSIGHTS_ENABLED=false

# Postgres — provision via Vercel Marketplace (Neon recommended).
DATABASE_URL=

# Cron auth — set in Vercel project env. Used to authorize /api/cron/scan calls.
CRON_SECRET=

# Tuning knobs
MIN_MARGIN_USD=15
MIN_MARGIN_PCT=0.25
MIN_CONFIDENCE=0.6
